# ─────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─────────────────────────────────────────────────────────────
# Brevo (Transactional & Bulk Email)
# Source: docs/reference_docs/api-connectors.md — Brevo connector
# ─────────────────────────────────────────────────────────────
BREVO_API_KEY=your-brevo-api-key
BREVO_FROM_EMAIL=your-sender@yourdomain.com
BREVO_FROM_NAME=Blur Studio

# ─────────────────────────────────────────────────────────────
# OpenAI
# Source: docs/reference_docs/api-connectors.md — OpenAI connector (GPT-5 / Responses API)
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key

# ─────────────────────────────────────────────────────────────
# Gemini (Google Generative Language)
# Source: docs/reference_docs/api-connectors.md — Gemini connector (gemini-2.5-flash)
# ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
